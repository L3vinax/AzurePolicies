{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {},
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.Authorization/policyDefinitions",
      "apiVersion": "2021-06-01",
      "name": "SQLMIDNSPolicy",
      "properties": {
        "displayName": "SQL Managed Identity DNS Policy",
        "description": "Enforce DNS settings for SQL Managed Identity",
        "mode": "All",
        "policyRule": {
          "if": {
            "field": "type",
            "equals": "Microsoft.Sql/managedInstances"
          },
          "then": {
            "effect": "audit"
          }
        }
      }
    }
  ],
  "outputs": {}
}
